---
import "../components/wardrobe/hyper/globals.css";
import "../components/wardrobe/system/globals.css";

interface Props {
    title: string;
    description?: string;
    system?: "hyper" | "system" | null;
    chrome?: "neutral" | "hyper" | "system" | "hidden";
}

const {
    title,
    description = "Wardrobe — themes for vibe-coded apps. Made by Martin Ibsen. MIT.",
    system = null,
    chrome = system === "hyper" ? "hyper" : system === "system" ? "system" : "neutral",
} = Astro.props;

const GITHUB_URL =
    "https://github.com/martinibsen/martinibsen.dk/tree/main/src/components/wardrobe";

const path = Astro.url.pathname.replace(/\/+$/, "") || "/";

// Hyper nav active states
const isHyperInstall = path === "/wardrobe/hyper/install";
const isHyperDemo = path.startsWith("/wardrobe/hyper/marathon-club");
const isHyperHome = path === "/wardrobe/hyper";

// System nav active states
const isSystemInstall = path === "/wardrobe/system/install";
const isSystemDemo = path.startsWith("/wardrobe/system/sequence");
const isSystemHome = path === "/wardrobe/system";

// "Built with..." pill — depends on which sphere we're in when chrome="hidden"
const builtWith = system === "system"
    ? { href: "/wardrobe/system", label: "← BUILT WITH SYSTEM", cls: "wbuilt--system" }
    : { href: "/wardrobe/hyper", label: "← Built with Hyper", cls: "wbuilt--hyper" };
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
</head>
<body data-system={system ?? undefined}>
    {chrome === "neutral" && (
        <header class="wnav wnav--neutral">
            <a class="wnav__brand" href="/wardrobe">Wardrobe</a>
            <nav class="wnav__links" aria-label="Wardrobe">
                <a href="/wardrobe#themes">Themes</a>
                <a href={GITHUB_URL} rel="noopener">GitHub</a>
            </nav>
        </header>
    )}

    {chrome === "hyper" && (
        <header class="wnav wnav--hyper">
            <a class="wnav__brand wnav__brand--hyper" href="/wardrobe">
                WARDROBE / HYPER.
            </a>
            <nav class="wnav__links wnav__links--hyper" aria-label="Hyper">
                <a
                    href="/wardrobe/hyper/install"
                    class:list={[isHyperInstall && "is-active"]}
                >
                    INSTALL
                </a>
                <a
                    href="/wardrobe/hyper/marathon-club"
                    class:list={[isHyperDemo && "is-active"]}
                >
                    DEMO
                </a>
                <a
                    href="/wardrobe/hyper"
                    class:list={[isHyperHome && "is-active"]}
                >
                    SYSTEM
                </a>
                <a href={GITHUB_URL} rel="noopener">GITHUB</a>
            </nav>
        </header>
    )}

    {chrome === "system" && (
        <header class="wnav wnav--system">
            <a class="wnav__brand wnav__brand--system" href="/wardrobe">
                WARDROBE / SYSTEM
            </a>
            <nav class="wnav__links wnav__links--system" aria-label="System">
                <a
                    href="/wardrobe/system/install"
                    class:list={[isSystemInstall && "is-active"]}
                >
                    INSTALL
                </a>
                <a
                    href="/wardrobe/system/sequence"
                    class:list={[isSystemDemo && "is-active"]}
                >
                    DEMO
                </a>
                <a
                    href="/wardrobe/system"
                    class:list={[isSystemHome && "is-active"]}
                >
                    OVERVIEW
                </a>
                <a href={GITHUB_URL} rel="noopener">GITHUB</a>
            </nav>
        </header>
    )}

    {chrome === "hidden" && (
        <a class:list={["wbuilt", builtWith.cls]} href={builtWith.href}>
            {builtWith.label}
        </a>
    )}

    <slot />

    <footer class:list={["wfoot", `wfoot--${chrome}`]}>
        <span>Built by <a href="/">Martin Ibsen</a></span>
        <span class="wfoot__sep" aria-hidden="true">·</span>
        <a href="/">martinibsen.dk</a>
        <span class="wfoot__sep" aria-hidden="true">·</span>
        <a href={GITHUB_URL} rel="noopener">GitHub</a>
        <span class="wfoot__sep" aria-hidden="true">·</span>
        <span>MIT</span>
    </footer>

    <style is:global>
        body[data-system="hyper"],
        body[data-system="system"] {
            margin: 0;
        }
        body:not([data-system]) {
            margin: 0;
            background: #ffffff;
            color: #0a0a0a;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                "Helvetica Neue", Arial, sans-serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            min-height: 100vh;
        }

        /* ===== STICKY NAV — shared ===== */
        .wnav {
            position: sticky;
            top: 0;
            z-index: 80;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 24px;
            line-height: 1;
        }
        .wnav__brand {
            font-size: 16px;
            font-weight: 600;
            color: inherit;
            text-decoration: none;
            letter-spacing: -0.01em;
        }
        .wnav__links {
            display: flex;
            gap: 22px;
            align-items: center;
        }
        .wnav__links a {
            color: inherit;
            text-decoration: none;
            font-size: 14px;
            border-bottom: 1px solid transparent;
            padding: 2px 0;
            transition: border-color 120ms ease, opacity 120ms ease;
        }
        .wnav__links a:hover { border-bottom-color: currentColor; }
        .wnav__links a.is-active { border-bottom-color: currentColor; }

        /* ===== Sphere A — neutral ===== */
        .wnav--neutral {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: saturate(140%) blur(8px);
            -webkit-backdrop-filter: saturate(140%) blur(8px);
            color: #0a0a0a;
            border-bottom: 1px solid #e5e5e5;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }
        .wnav--neutral .wnav__links a:not(.is-active) { color: #525252; }
        .wnav--neutral .wnav__links a:hover { color: #0a0a0a; }

        /* ===== Sphere B — hyper ===== */
        .wnav--hyper {
            background: var(--color-bg, #efff71);
            color: var(--color-fg, #3a1e1e);
            border-bottom: 1px solid var(--color-fg, #3a1e1e);
            font-family: var(--font-display, "Anton", "Impact", sans-serif);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .wnav__brand--hyper {
            font-size: 18px;
            font-weight: 400;
            letter-spacing: -0.01em;
        }
        .wnav--hyper .wnav__links a { font-size: 13px; }

        /* ===== Sphere B — system ===== */
        .wnav--system {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: saturate(140%) blur(8px);
            -webkit-backdrop-filter: saturate(140%) blur(8px);
            color: #0d0d0d;
            border-bottom: 1px solid #eeeeee;
            font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .wnav__brand--system {
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 1.5px;
        }
        .wnav--system .wnav__links a {
            font-size: 12px;
            color: #0d0d0d;
        }
        .wnav--system .wnav__links a.is-active {
            border-bottom-width: 2px;
            border-bottom-color: #0d0d0d;
        }

        /* ===== Built-with pill — chrome="hidden" ===== */
        .wbuilt {
            position: fixed;
            top: 16px;
            right: 16px;
            z-index: 90;
            display: inline-flex;
            align-items: center;
            line-height: 1;
            text-decoration: none;
            transition: background 120ms ease, color 120ms ease;
        }
        .wbuilt--hyper {
            background: var(--color-surface, #ffffff);
            color: var(--color-fg, #3a1e1e);
            border: 1px solid var(--color-fg, #3a1e1e);
            border-radius: var(--radius-pill, 32px);
            padding: 7px 14px;
            font-family: var(--font-display, "Anton", "Impact", sans-serif);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-size: 11px;
        }
        .wbuilt--hyper:hover {
            background: var(--color-fg, #3a1e1e);
            color: var(--color-bg, #efff71);
        }
        .wbuilt--system {
            background: #ffffff;
            color: #0d0d0d;
            border: 1px solid #0d0d0d;
            border-radius: 2px;
            padding: 7px 12px;
            font-family: "JetBrains Mono", ui-monospace, monospace;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 10px;
        }
        .wbuilt--system:hover {
            background: #0d0d0d;
            color: #ffffff;
        }

        /* ===== FOOTER ===== */
        .wfoot {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            padding: 24px;
            font-size: 12px;
            line-height: 1.4;
            text-align: center;
            flex-wrap: wrap;
        }
        .wfoot a { color: inherit; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 120ms ease; }
        .wfoot a:hover { border-bottom-color: currentColor; }
        .wfoot__sep { opacity: 0.5; }

        .wfoot--neutral {
            border-top: 1px solid #e5e5e5;
            color: #525252;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }
        .wfoot--hyper {
            border-top: 1px solid var(--color-fg, #3a1e1e);
            color: var(--color-fg, #3a1e1e);
            font-family: var(--font-body, "Georgia", serif);
            opacity: 0.75;
        }
        .wfoot--system {
            border-top: 1px solid #eeeeee;
            color: #888888;
            font-family: "Space Grotesk", -apple-system, sans-serif;
            font-size: 11px;
        }
        .wfoot--system .wfoot__sep { color: #bbb; }
        .wfoot--hidden {
            /* For chrome="hidden" pages — pick footer style based on body data-system */
            border-top: 1px solid var(--color-fg, #3a1e1e);
            color: var(--color-fg, #3a1e1e);
            font-family: var(--font-body, "Georgia", serif);
            opacity: 0.75;
        }
        body[data-system="system"] .wfoot--hidden {
            border-top: 1px solid #eeeeee;
            color: #888888;
            font-family: "Space Grotesk", -apple-system, sans-serif;
            font-size: 11px;
            opacity: 1;
        }

        @media (max-width: 540px) {
            .wnav { padding: 12px 18px; }
            .wnav__links { gap: 14px; }
            .wnav--hyper .wnav__links a { font-size: 12px; }
            .wnav--system .wnav__links a { font-size: 11px; }
            .wbuilt { top: 12px; right: 12px; }
            .wbuilt--hyper { padding: 6px 12px; font-size: 10px; }
            .wbuilt--system { padding: 6px 10px; font-size: 9px; }
        }
    </style>

    <script is:inline>
        // Lightweight PostHog event helper if window.posthog is available.
        window.wardrobeTrack = function (event, props) {
            try {
                if (window.posthog && typeof window.posthog.capture === "function") {
                    window.posthog.capture(event, props || {});
                }
                if (typeof console !== "undefined") {
                    console.debug("[wardrobe]", event, props || {});
                }
            } catch (e) {
                /* noop */
            }
        };
    </script>
</body>
</html>
